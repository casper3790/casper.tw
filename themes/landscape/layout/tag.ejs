<section class="tag-page">
  <%
    const tagPath = String(page.path || '').replace(/index\.html$/, '').replace(/\/$/, '');
    const tagParts = tagPath.split('/').filter(Boolean);
    const tagLang = tagParts[0] === 'zh' ? 'zh' : (tagParts[0] === 'ja' ? 'ja' : 'en');
    const inferPostLang = function(post) {
      const postPath = String(post.path || '').replace(/index\.html$/, '').replace(/\/$/, '');
      const postParts = postPath.split('/').filter(Boolean);
      if (postParts[0] === 'zh') return 'zh';
      if (postParts[0] === 'ja') return 'ja';
      const raw = strip_html(post.content || post.description || '').replace(/\s+/g, ' ').trim();
      const cjk = (raw.match(/[\u4e00-\u9fff\u3040-\u30ff\u3400-\u4dbf]/g) || []).length;
      const kana = (raw.match(/[\u3040-\u30ff]/g) || []).length;
      const latin = (raw.match(/[A-Za-z]/g) || []).length;
      return kana > 12 ? 'ja' : (cjk > latin ? 'zh' : 'en');
    };
    const tagPostsRaw = page.posts && page.posts.toArray ? page.posts.toArray() : (page.posts ? page.posts.data || [] : []);
    const tagPosts = tagPostsRaw.filter(function(post) { return inferPostLang(post) === tagLang; });
  %>
  <h1 class="section-title">Tag: <%= page.tag.name %></h1>

  <% if (tagPosts.length) { %>
    <div class="writing-list">
      <% tagPosts.forEach(function(post) { %>
        <article class="writing-item">
          <div class="writing-date"><%= date(post.date, 'YYYY-MM-DD') %></div>
          <div class="writing-title">
            <a href="<%= url_for(post.path) %>"><%= post.title %></a>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <p>No posts in this tag.</p>
  <% } %>
</section>
