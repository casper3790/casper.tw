<%
  const htmlPath = String(page.path || '').replace(/index\.html$/, '').replace(/\/$/, '');
  const htmlParts = htmlPath.split('/').filter(Boolean);
  const normalizeHtmlLang = function(value) {
    const normalized = String(value || '').toLowerCase();
    if (normalized === 'zh' || normalized === 'zh-tw' || normalized === 'zh-hant') return 'zh-Hant';
    if (normalized === 'ja' || normalized === 'jp') return 'ja';
    if (normalized === 'en') return 'en';
    return '';
  };
  const explicitHtmlLang = htmlParts[0] === 'zh' ? 'zh-Hant' : (htmlParts[0] === 'ja' ? 'ja' : (htmlParts[0] === 'en' ? 'en' : ''));
  const htmlLang = explicitHtmlLang || normalizeHtmlLang(page.site_lang) || 'en';
%>
<!DOCTYPE html>
<html lang="<%= htmlLang %>">
<head>
  <%- partial('_partial/head') %>
</head>
<body>
  <div class="site-wrapper">
    <%- partial('_partial/header') %>

    <main class="main-container">
      <%- body %>
    </main>

    <%- partial('_partial/footer') %>
  </div>
</body>
</html>
