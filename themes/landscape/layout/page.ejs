<%
  const normalizedPagePath = String(page.path || '').replace(/index\.html$/, '').replace(/\/$/, '');
  const pageParts = normalizedPagePath.split('/').filter(Boolean);
  const normalizePageLang = function(value) {
    const normalized = String(value || '').toLowerCase();
    if (normalized === 'zh' || normalized === 'zh-tw' || normalized === 'zh-hant') return 'zh';
    if (normalized === 'ja' || normalized === 'jp') return 'ja';
    if (normalized === 'en') return 'en';
    return '';
  };
  const explicitPageLang = ['en', 'zh', 'ja'].includes(pageParts[0]) ? pageParts[0] : '';
  const pageLang = explicitPageLang || normalizePageLang(page.site_lang) || 'en';
  const localPageParts = explicitPageLang ? pageParts.slice(1) : pageParts;
  const pageSection = localPageParts[0] || 'home';
  const isExperienceLanding = pageSection === 'experience' && localPageParts.length === 1;
  const isExperienceDetail = pageSection === 'experience' && localPageParts.length === 2;
  const i18nPagePaths = [
    '',
    'dashboard',
    'experience',
    'projects',
    'labs',
    'writing',
    'timeline',
    'en/experience',
    'zh',
    'zh/dashboard',
    'zh/experience',
    'zh/projects',
    'zh/labs',
    'zh/writing',
    'zh/timeline',
    'ja',
    'ja/dashboard',
    'ja/experience',
    'ja/projects',
    'ja/labs',
    'ja/writing',
    'ja/timeline'
  ];
  const isI18nPage = i18nPagePaths.includes(normalizedPagePath);
  const pageCopy = {
    en: {
      pageKicker: 'Notebook Page',
      searchPlaceholder: 'Search posts...',
      searchLoadFailed: 'Failed to load search index.',
      searchHint: 'Type something to search.',
      searchEmpty: 'No matching posts found.',
      untitled: 'Untitled'
    },
    zh: {
      pageKicker: '筆記頁',
      searchPlaceholder: '搜尋文章...',
      searchLoadFailed: '搜尋索引載入失敗。',
      searchHint: '輸入關鍵字開始搜尋。',
      searchEmpty: '找不到符合的文章。',
      untitled: '未命名'
    },
    ja: {
      pageKicker: 'ノートページ',
      searchPlaceholder: '記事を検索...',
      searchLoadFailed: '検索インデックスを読み込めませんでした。',
      searchHint: 'キーワードを入力して検索してください。',
      searchEmpty: '一致する記事は見つかりませんでした。',
      untitled: '無題'
    }
  }[pageLang];
%>

<% if (isExperienceLanding) { %>
  <%- partial('_partial/experience-page') %>
<% } else if (isExperienceDetail) { %>
  <%- partial('_partial/experience-detail') %>
<% } else if (isI18nPage) { %>
  <%- partial('_partial/i18n-page') %>
<% } else { %>
  <article class="page-content notebook-page<%= pageSection === 'about' ? ' about-page' : '' %>">
    <header class="page-header">
      <div class="page-kicker"><%= pageCopy.pageKicker %></div>
      <h1 class="section-title"><%= page.title %></h1>
    </header>

    <div class="page-body">
      <% if (page.title === 'Search') { %>
        <div class="search-box-wrap">
          <input
            id="local-search-input"
            class="search-input"
            type="text"
            placeholder="<%= pageCopy.searchPlaceholder %>"
            autocomplete="off"
          />
          <div id="local-search-results" class="search-results"></div>
        </div>

        <script>
          (async function () {
            const input = document.getElementById('local-search-input');
            const results = document.getElementById('local-search-results');

            let posts = [];

            try {
              const res = await fetch('<%= url_for('/search.json') %>');
              posts = await res.json();
            } catch (err) {
              results.innerHTML = '<p><%= pageCopy.searchLoadFailed %></p>';
              return;
            }

            function escapeHtml(str) {
              return str
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
            }

            function stripHtml(html) {
              const div = document.createElement('div');
              div.innerHTML = html;
              return div.textContent || div.innerText || '';
            }

            function highlight(text, keyword) {
              if (!keyword) return escapeHtml(text);
              const escaped = escapeHtml(text);
              const pattern = new RegExp(`(${keyword.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'ig');
              return escaped.replace(pattern, '<mark>$1</mark>');
            }

            function renderResults(list, keyword) {
              if (!keyword.trim()) {
                results.innerHTML = '<p class="search-hint"><%= pageCopy.searchHint %></p>';
                return;
              }

              if (!list.length) {
                results.innerHTML = '<p class="search-empty"><%= pageCopy.searchEmpty %></p>';
                return;
              }

              results.innerHTML = list.map(post => {
                const rawText = stripHtml(post.content || '');
                const excerpt = rawText.slice(0, 180);
                return `
                  <article class="search-result-item">
                    <div class="search-result-date">${post.date ? post.date.slice(0, 10) : ''}</div>
                    <div class="search-result-main">
                      <a class="search-result-title" href="${post.url}">${highlight(post.title || '<%= pageCopy.untitled %>', keyword)}</a>
                      <p class="search-result-excerpt">${highlight(excerpt, keyword)}...</p>
                    </div>
                  </article>
                `;
              }).join('');
            }

            input.addEventListener('input', function () {
              const keyword = this.value.toLowerCase().trim();

              const matched = posts.filter(post => {
                const title = (post.title || '').toLowerCase();
                const content = stripHtml(post.content || '').toLowerCase();
                return title.includes(keyword) || content.includes(keyword);
              });

              renderResults(matched, this.value.trim());
            });

            renderResults([], '');
          })();
        </script>
      <% } else { %>
        <%- page.content %>
      <% } %>
    </div>
  </article>
<% } %>
