<%
  const rawPostText = strip_html(page.content || '').replace(/\s+/g, ' ').trim();
  const cjkPostChars = (rawPostText.match(/[\u4e00-\u9fff\u3040-\u30ff\u3400-\u4dbf]/g) || []).length;
  const postWords = rawPostText.replace(/[\u4e00-\u9fff\u3040-\u30ff\u3400-\u4dbf]/g, ' ').split(/\s+/).filter(Boolean).length;
  const postMinutes = Math.max(1, Math.ceil((postWords + cjkPostChars / 2) / 220));
  const futureSelfRaw = page.future_self || page.futureSelf || page.future_note || page.futureNote || '';
  const futureSelfLines = Array.isArray(futureSelfRaw)
    ? futureSelfRaw.map(function(line) { return String(line || '').trim(); }).filter(Boolean)
    : String(futureSelfRaw || '').split(/\r?\n/).map(function(line) { return line.trim(); }).filter(Boolean);
  const kanaPostChars = (rawPostText.match(/[\u3040-\u30ff]/g) || []).length;
  const latinPostChars = (rawPostText.match(/[A-Za-z]/g) || []).length;
  const postLang = kanaPostChars > 12 ? 'ja' : (cjkPostChars > latinPostChars ? 'zh' : 'en');
  const postCopy = {
    en: {
      kicker: 'Field Note',
      readTimeSuffix: 'min read',
      futureSelf: 'Note to my future self',
      top: 'Top'
    },
    zh: {
      kicker: '探索筆記',
      readTimeSuffix: '分鐘閱讀',
      futureSelf: '給未來的自己',
      top: '回到頂端'
    },
    ja: {
      kicker: '探索ノート',
      readTimeSuffix: '分で読めます',
      futureSelf: '未来の自分へ',
      top: '上へ'
    }
  }[postLang];
%>

<div class="reading-progress" aria-hidden="true"><span data-reading-progress></span></div>

<article class="post-content field-note-page os-reading-layout">
  <header class="post-header field-note-header">
    <div class="post-kicker"><%= postCopy.kicker %></div>
    <h1 class="post-title"><%= page.title %></h1>

    <div class="post-meta">
      <time><%= date(page.date, 'YYYY-MM-DD') %></time>
      <span><%= postMinutes %> <%= postCopy.readTimeSuffix %></span>
    </div>
  </header>

  <div class="post-body">
    <%- page.content %>
  </div>

  <% if (futureSelfLines.length) { %>
    <section class="future-self-note" aria-labelledby="future-self-title">
      <h2 id="future-self-title"><%= postCopy.futureSelf %></h2>
      <% futureSelfLines.forEach(function(line) { %>
        <p><%= line %></p>
      <% }) %>
    </section>
  <% } %>
</article>

<button class="back-to-top-button" type="button" data-back-top hidden><%= postCopy.top %></button>

<%- partial('_partial/os-post-tools') %>
