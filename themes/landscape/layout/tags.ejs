<section class="tags-page">
  <%
    const tagsPath = String(page.path || '').replace(/index\.html$/, '').replace(/\/$/, '');
    const tagsParts = tagsPath.split('/').filter(Boolean);
    const tagsLang = tagsParts[0] === 'zh' ? 'zh' : (tagsParts[0] === 'ja' ? 'ja' : 'en');
    const visibleTags = [];
    if (site.tags && site.tags.length) {
      site.tags.each(function(tag) {
        const posts = tag.posts && tag.posts.toArray ? tag.posts.toArray() : (tag.posts ? tag.posts.data || [] : []);
        const count = posts.filter(function(post) {
          return detect_post_language(post) === tagsLang;
        }).length;
        if (count) visibleTags.push({ name: tag.name, path: tag.path, length: count });
      });
    }
  %>
  <h1 class="section-title">Tags</h1>

  <% if (visibleTags.length) { %>
    <div class="tags-list-grid">
      <% visibleTags.forEach(function(tag) { %>
        <a class="tag-card" href="<%= url_for(tag.path) %>">
          <span class="tag-name">#<%= tag.name %></span>
          <span class="tag-count"><%= tag.length %> posts</span>
        </a>
      <% }) %>
    </div>
  <% } else { %>
    <p>No tags yet.</p>
  <% } %>
</section>
