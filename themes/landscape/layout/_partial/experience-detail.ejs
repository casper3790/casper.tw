%>

<% if (expSlug === 'projects') { %>
<article class="engineering-projects-page" itemscope itemtype="https://schema.org/CollectionPage">
  <nav class="engineering-projects-breadcrumbs" aria-label="Breadcrumbs">
    <a href="<%= url_for(expLang === 'en' ? '/' : '/' + expLang + '/') %>"><%= projectsCopy.home %></a>
    <span aria-hidden="true">/</span>
    <a href="<%= url_for(expBase) %>"><%= projectsCopy.experience %></a>
    <span aria-hidden="true">/</span>
    <span aria-current="page"><%= projectsCopy.title %></span>
  </nav>

  <header class="engineering-projects-header">
    <h1 itemprop="name"><%= projectsCopy.title %></h1>
    <p itemprop="description"><%= projectsCopy.subtitle %></p>
    <div class="engineering-projects-header-meta">
      <% [page.experience_date, projectText(page.role)].filter(Boolean).forEach(function(item) { %><span><%= item %></span><% }) %>
    </div>
  </header>

  <% if (projectSummaryCards.length) { %>
    <section class="engineering-projects-summary" aria-labelledby="engineering-projects-summary-title">
      <h2 id="engineering-projects-summary-title"><%= projectsCopy.summary %></h2>
      <div class="engineering-projects-summary-grid">
        <% projectSummaryCards.forEach(function(row) { %>
          <article>
            <span><%= row[0] %></span>
            <strong><%= row[1] %></strong>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>

  <section class="engineering-projects-list" aria-label="<%= projectsCopy.aria %>">
    <% projectCards.forEach(function(project) { %>
      <article class="engineering-project-card">
        <div class="engineering-project-card-main">
          <h2><%= project.title %></h2>
          <% if (project.topic) { %><p><%= project.topic %></p><% } %>
          <% if (project.outcome) { %><small><%= projectsCopy.outcome %>: <%= project.outcome %></small><% } %>
        </div>
        <div class="engineering-project-card-meta">
          <% [project.year, project.role, project.organization || project.type].filter(Boolean).forEach(function(item) { %><span><%= item %></span><% }) %>
        </div>
        <% if (project.tags.length) { %>
          <div class="engineering-project-tags">
            <% project.tags.forEach(function(tag) { %><span><%= tag %></span><% }) %>
          </div>
        <% } %>
      </article>
    <% }) %>
  </section>

  <section class="engineering-projects-skills" aria-labelledby="engineering-projects-skills-title">
    <h2 id="engineering-projects-skills-title"><%= projectsCopy.skills %></h2>
    <div class="engineering-projects-skill-grid">
      <% projectsCopy.groups.forEach(function(group) { %>
        <article>
          <h3><%= group[0] %></h3>
          <div class="engineering-project-tags">
            <% group[1].forEach(function(item) { %><span><%= item %></span><% }) %>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <% if (expGallery.length) { %>
    <section class="engineering-projects-gallery" aria-labelledby="engineering-projects-gallery-title">
      <h2 id="engineering-projects-gallery-title"><%= projectsCopy.gallery %></h2>
      <div class="engineering-projects-gallery-grid">
        <% expGallery.forEach(function(image) { %>
          <img src="<%= url_for(image.src) %>" alt="<%= image.alt || projectsCopy.title + ' gallery image' %>" loading="lazy">
        <% }) %>
      </div>
    </section>
  <% } %>

  <section class="engineering-projects-links" aria-labelledby="engineering-projects-links-title">
    <h2 id="engineering-projects-links-title"><%= projectsCopy.links %></h2>
    <div class="engineering-projects-link-list">
      <a href="<%= url_for(expBase) %>"><%= expText.back %></a>
      <% if (expPrev) { %><a href="<%= expUrl(expPrev.slug) %>"><%= expText.previous %>: <%= expPrev.title %></a><% } %>
      <% if (expNext) { %><a href="<%= expUrl(expNext.slug) %>"><%= expText.next %>: <%= expNext.title %></a><% } %>
    </div>
  </section>

  <script type="application/ld+json"><%- JSON.stringify(schema) %></script>
</article>
<% } else if (expSlug === 'research') { %>
<article class="research-v1-page" itemscope itemtype="https://schema.org/CreativeWork">
  <header class="research-v1-header">
    <p><%= researchCopy.kicker %></p>
    <h1 itemprop="name"><%= researchCopy.title %></h1>
    <div class="research-v1-subtitle" itemprop="description">
      <% researchCopy.subtitles.forEach(function(line) { %><span><%= line %></span><% }) %>
    </div>
  </header>

  <div class="research-direction-list">
    <% researchCopy.items.forEach(function(item, index) { %>
      <article class="research-direction-item">
        <span class="research-direction-index"><%= String(index + 1).padStart(2, '0') %></span>
        <h2><%= item.title %></h2>
        <dl>
          <div>
            <dt><%= researchCopy.labels.question %></dt>
            <dd><%= item.question %></dd>
          </div>
          <div>
            <dt><%= researchCopy.labels.why %></dt>
            <dd><%= item.why %></dd>
          </div>
          <div>
            <dt><%= researchCopy.labels.direction %></dt>
            <dd><%= item.direction %></dd>
          </div>
        </dl>
      </article>
    <% }) %>
  </div>

  <script type="application/ld+json"><%- JSON.stringify(schema) %></script>
</article>
<% } else { %>
<article class="page-content experience-detail" itemscope itemtype="https://schema.org/CreativeWork">
  <nav class="tag-cloud-list experience-breadcrumbs" aria-label="Breadcrumbs">
    <a class="tag-cloud-link" href="<%= url_for(expLang === 'en' ? '/' : '/' + expLang + '/') %>"><%= expText.home %></a>
    <a class="tag-cloud-link" href="<%= url_for(expBase) %>"><%= expText.experience %></a>
    <span class="tag-cloud-link" aria-current="page"><%= expTitle %></span>
  </nav>

  <header class="project-page-hero experience-hero">
    <img src="<%= url_for(expCover) %>" alt="<%= expTitle %> cover image" loading="lazy">
    <h1 itemprop="name"><%= expTitle %></h1>
    <% if (expSummary) { %><p itemprop="description"><%= expSummary %></p><% } %>
    <% if (expTags.length) { %>
      <div class="featured-project-tags" aria-label="<%= expText.tags %>">
        <span><%= expText.tags %></span>
        <% expTags.forEach(function(tag) { %><strong><%= tag %></strong><% }) %>
      </div>
    <% } %>
  </header>

  <section class="featured-projects" aria-labelledby="experience-meta-title">
    <h2 id="experience-meta-title" class="section-title"><%= expText.summary %></h2>
    <div class="featured-project-grid">
      <% [
        [expText.title, expTitle],
        [expText.organization, page.organization],
        [expText.date, page.experience_date],
        [expText.location, page.location],
        [expText.category, page.category],
        [expText.role, page.role],
        [expText.result, page.result]
      ].forEach(function(row) { if (row[1]) { %>
        <article class="featured-project-card">
          <h3><%= row[0] %></h3>
          <p><%= row[1] %></p>
        </article>
      <% } }) %>
    </div>
  </section>

  <section class="os-section os-timeline-section" aria-labelledby="experience-timeline-title">
    <div class="os-section-header">
      <p class="os-section-kicker"><%= expText.experience %></p>
      <h2 id="experience-timeline-title" class="section-title"><%= expText.timeline %></h2>
    </div>
    <div class="os-timeline">
      <article class="timeline-card">
        <time><%= page.experience_date || '' %></time>
        <div>
          <h3><%= expTitle %></h3>
          <p><%= expSummary || page.result || page.category || '' %></p>
        </div>
      </article>
    </div>
  </section>

  <section class="page-body" itemprop="text">
    <%- expBody %>
  </section>

  <% if (expSkills.length || expTechnologies.length) { %>
    <section class="tag-cloud" aria-labelledby="experience-skills-title">
      <h2 id="experience-skills-title" class="section-title"><%= expText.skills %></h2>
      <div class="tag-cloud-list">
        <% expSkills.concat(expTechnologies).forEach(function(item) { %>
          <span class="tag-cloud-link"><%= item %></span>
        <% }) %>
      </div>
    </section>
  <% } %>

  <section class="featured-projects" aria-labelledby="experience-gallery-title">
    <h2 id="experience-gallery-title" class="section-title"><%= expText.gallery %></h2>
    <% if (expGallery.length) { %>
      <div class="featured-project-grid">
        <% expGallery.forEach(function(image) { %>
          <article class="featured-project-card">
            <img src="<%= url_for(image.src) %>" alt="<%= image.alt || expTitle + ' gallery image' %>" loading="lazy">
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <p><%= expText.noGallery %></p>
    <% } %>
  </section>

  <section class="tag-cloud" aria-labelledby="experience-links-title">
    <h2 id="experience-links-title" class="section-title"><%= expText.links %></h2>
    <div class="tag-cloud-list">
      <a class="tag-cloud-link" href="<%= url_for(expBase) %>"><%= expText.back %></a>
      <% if (expPrev) { %><a class="tag-cloud-link" href="<%= expUrl(expPrev.slug) %>"><%= expText.previous %>: <%= expPrev.title %></a><% } %>
      <% if (expNext) { %><a class="tag-cloud-link" href="<%= expUrl(expNext.slug) %>"><%= expText.next %>: <%= expNext.title %></a><% } %>
    </div>
  </section>

  <% if (expRelated.length) { %>
    <section class="featured-projects" aria-labelledby="experience-related-title">
      <h2 id="experience-related-title" class="section-title"><%= expText.related %></h2>
      <div class="featured-project-grid">
        <% expRelated.forEach(function(item) { %>
          <a class="featured-project-card" href="<%= expUrl(item.slug) %>">
            <h3><%= item.title %></h3>
            <p><%= item.category %></p>
          </a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <script type="application/ld+json"><%- JSON.stringify(schema) %></script>
</article>
<% } %>
