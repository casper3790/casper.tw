  const projectText = function(value) {
    const cleanValue = normalizeProjectLine(value);
    return (projectTranslations[expLang] && projectTranslations[expLang][cleanValue]) || cleanValue;
  };
  const projectField = function(lines, key) {
    const labels = projectsFieldLabels[key] || [];
    for (let i = 0; i < lines.length; i += 1) {
      for (let j = 0; j < labels.length; j += 1) {
        const label = labels[j];
        const prefixColon = label + ':';
        const prefixFullColon = label + '：';
        if (lines[i].indexOf(prefixColon) === 0) return lines[i].slice(prefixColon.length).trim();
