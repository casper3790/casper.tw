<%
  const expPath = String(page.path || '').replace(/index\.html$/, '').replace(/\/$/, '');
  const expParts = expPath.split('/').filter(Boolean);
  const expLang = expParts[0] === 'zh' ? 'zh' : (expParts[0] === 'ja' ? 'ja' : 'en');
  const experienceOrder = {
    en: [
      { slug: 'competitions', title: 'Competitions', category: 'Competitions' },
      { slug: 'awards', title: 'Awards', category: 'Awards' },
      { slug: 'certifications', title: 'Certifications', category: 'Certifications' },
      { slug: 'workshops', title: 'Workshops', category: 'Workshops' },
      { slug: 'speaking', title: 'Speaking', category: 'Speaking' },
      { slug: 'community', title: 'Community', category: 'Community' },
      { slug: 'ctf', title: 'CTF Experience', category: 'CTF Experience' },
      { slug: 'projects', title: 'Projects', category: 'Projects' },
      { slug: 'research', title: 'Research', category: 'Research' }
    ],
    zh: [
      { slug: 'competitions', title: '競賽', category: '競賽' },
      { slug: 'awards', title: '獎項', category: '獎項' },
      { slug: 'certifications', title: '證照', category: '證照' },
      { slug: 'workshops', title: '研習', category: '研習' },
      { slug: 'speaking', title: '教學與分享', category: '教學與分享' },
      { slug: 'community', title: '社群', category: '社群' },
      { slug: 'ctf', title: 'CTF 經歷', category: 'CTF Experience' },
      { slug: 'projects', title: '專案', category: '專案' },
      { slug: 'research', title: '研究', category: '研究' }
    ],
    ja: [
      { slug: 'competitions', title: 'コンペティション', category: 'コンペティション' },
      { slug: 'awards', title: '受賞歴', category: '受賞歴' },
      { slug: 'certifications', title: '資格', category: '資格' },
      { slug: 'workshops', title: 'ワークショップ', category: 'ワークショップ' },
      { slug: 'speaking', title: '登壇・指導', category: '登壇・指導' },
      { slug: 'community', title: 'コミュニティ', category: 'コミュニティ' },
      { slug: 'ctf', title: 'CTF 経験', category: 'CTF Experience' },
      { slug: 'projects', title: 'プロジェクト', category: 'プロジェクト' },
      { slug: 'research', title: '研究', category: '研究' }
    ]
  }[expLang];
  const expLocalParts = expLang === 'en' ? expParts : expParts.slice(1);
  const expSlug = expLocalParts[1] || '';
  const expIndex = experienceOrder.findIndex(function(item) { return item.slug === expSlug; });
  const expPrev = expIndex > 0 ? experienceOrder[expIndex - 1] : null;
  const expNext = expIndex >= 0 && expIndex < experienceOrder.length - 1 ? experienceOrder[expIndex + 1] : null;
  const expBase = expLang === 'en' ? '/experience/' : '/' + expLang + '/experience/';
  const expUrl = function(slug) { return url_for(expBase + slug + '/'); };
  const expTitle = page.title || (experienceOrder[expIndex] && experienceOrder[expIndex].title) || 'Experience';
  const expCover = page.cover || '/images/casper-og.png';
  const expSummary = page.summary || page.description || '';
  const expTags = Array.isArray(page.tags) ? page.tags : (page.keywords ? String(page.keywords).split(',').map(function(tag) { return tag.trim(); }).filter(Boolean) : []);
  const expSkills = Array.isArray(page.skills) ? page.skills : [];
  const expTechnologies = Array.isArray(page.technologies) ? page.technologies : [];
  const expGallery = Array.isArray(page.gallery) ? page.gallery : [];
  const expLinks = Array.isArray(page.related_links) ? page.related_links : [];
  const expBody = String(page.content || '').replace(/^\s*<h1[^>]*>[\s\S]*?<\/h1>\s*/i, '');
  const expText = {
    en: {
      home: 'Home',
      experience: 'Experience',
      tags: 'Tags',
      summary: 'Summary',
      timeline: expLang === 'zh' ? '時間軸' : (expLang === 'ja' ? 'タイムライン' : 'Timeline'),
      gallery: 'Gallery',
      noGallery: 'No gallery images available yet.',
      links: 'Related Links',
      back: 'Back to Experience',
      related: 'Related Experiences',
      nav: 'Experience navigation',
      share: 'Share this experience',
      linkedin: 'Share on LinkedIn',
      x: 'Share on X',
      previous: 'Previous',
      next: 'Next',
      title: 'Title',
      organization: 'Organization',
      date: 'Date',
      location: 'Location',
      category: 'Category',
      role: 'Role',
      result: 'Result / Achievement',
      skills: 'Skills & Technologies'
    },
    zh: {
      home: '首頁',
      experience: '經歷',
      tags: '標籤',
      summary: '摘要',
      timeline: '時間軸',
      gallery: '圖集',
      noGallery: '目前尚無圖集。',
      links: '相關連結',
      back: '返回經歷',
      related: '相關經歷',
      nav: '經歷導覽',
      share: '分享這筆經歷',
      linkedin: '分享到 LinkedIn',
      x: '分享到 X',
      previous: '上一頁',
      next: '下一頁',
      title: '標題',
      organization: '組織',
      date: '日期',
      location: '地點',
      category: '分類',
      role: '角色',
      result: '成果 / 成就',
      skills: '技能與技術'
    },
    ja: {
      home: 'ホーム',
      experience: '経歴',
      tags: 'タグ',
      summary: '概要',
      timeline: 'タイムライン',
      gallery: 'ギャラリー',
      noGallery: '現在、ギャラリー画像はありません。',
      links: '関連リンク',
      back: '経歴へ戻る',
      related: '関連する経歴',
      nav: '経歴ナビゲーション',
      share: 'この経歴を共有',
      linkedin: 'LinkedIn で共有',
      x: 'X で共有',
      previous: '前へ',
      next: '次へ',
      title: 'タイトル',
      organization: '組織',
      date: '日付',
      location: '場所',
      category: 'カテゴリ',
      role: '役割',
      result: '成果 / 実績',
      skills: 'スキルと技術'
    }
  }[expLang];
  const expRelated = experienceOrder.filter(function(item) {
    return item.slug !== expSlug && (item.category === page.category || (page.related_categories || []).indexOf(item.category) >= 0);
  }).slice(0, 3);
  const expBaseUrl = (config.url || '').replace(/\/$/, '');
  const expRootPath = config.root || '/';
  const expAbsoluteUrl = function(path) {
    if (/^https?:\/\//.test(path)) return path;
    let localPath = url_for(path).replace(/index\.html$/, '');
    if (expRootPath !== '/' && localPath.indexOf(expRootPath) === 0) {
      localPath = localPath.slice(expRootPath.length - 1);
    }
    return expBaseUrl + localPath;
  };
  const canonical = expAbsoluteUrl(page.path || '/');
  const schema = {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: expTitle,
    description: strip_html(expSummary || page.description || '').replace(/\s+/g, ' ').trim(),
    url: canonical,
    image: expAbsoluteUrl(expCover),
    datePublished: page.date || undefined,
    keywords: expTags.concat(expSkills).join(', '),
    about: page.category || 'Experience'
  };
%>

<article class="page-content experience-detail" itemscope itemtype="https://schema.org/CreativeWork">
  <nav class="tag-cloud-list experience-breadcrumbs" aria-label="Breadcrumbs">
    <a class="tag-cloud-link" href="<%= url_for(expLang === 'en' ? '/' : '/' + expLang + '/') %>"><%= expText.home %></a>
    <a class="tag-cloud-link" href="<%= url_for(expBase) %>"><%= expText.experience %></a>
    <span class="tag-cloud-link" aria-current="page"><%= expTitle %></span>
  </nav>

  <header class="project-page-hero experience-hero">
    <img src="<%= url_for(expCover) %>" alt="<%= expTitle %> cover image" loading="lazy">
    <h1 itemprop="name"><%= expTitle %></h1>
    <% if (expSummary) { %><p itemprop="description"><%= expSummary %></p><% } %>
    <% if (expTags.length) { %>
      <div class="featured-project-tags" aria-label="<%= expText.tags %>">
        <span><%= expText.tags %></span>
        <% expTags.forEach(function(tag) { %><strong><%= tag %></strong><% }) %>
      </div>
    <% } %>
  </header>

  <section class="featured-projects" aria-labelledby="experience-meta-title">
    <h2 id="experience-meta-title" class="section-title"><%= expText.summary %></h2>
    <div class="featured-project-grid">
      <% [
        [expText.title, expTitle],
        [expText.organization, page.organization],
        [expText.date, page.experience_date],
        [expText.location, page.location],
        [expText.category, page.category],
        [expText.role, page.role],
        [expText.result, page.result]
      ].forEach(function(row) { if (row[1]) { %>
        <article class="featured-project-card">
          <h3><%= row[0] %></h3>
          <p><%= row[1] %></p>
        </article>
      <% } }) %>
    </div>
  </section>

  <section class="os-section os-timeline-section" aria-labelledby="experience-timeline-title">
    <div class="os-section-header">
      <p class="os-section-kicker"><%= expText.experience %></p>
      <h2 id="experience-timeline-title" class="section-title"><%= expText.timeline %></h2>
    </div>
    <div class="os-timeline">
      <article class="timeline-card">
        <time><%= page.experience_date || '' %></time>
        <div>
          <h3><%= expTitle %></h3>
          <p><%= expSummary || page.result || page.category || '' %></p>
        </div>
      </article>
    </div>
  </section>

  <section class="page-body" itemprop="text">
    <%- expBody %>
  </section>

  <% if (expSkills.length || expTechnologies.length) { %>
    <section class="tag-cloud" aria-labelledby="experience-skills-title">
      <h2 id="experience-skills-title" class="section-title"><%= expText.skills %></h2>
      <div class="tag-cloud-list">
        <% expSkills.concat(expTechnologies).forEach(function(item) { %>
          <span class="tag-cloud-link"><%= item %></span>
        <% }) %>
      </div>
    </section>
  <% } %>

  <section class="featured-projects" aria-labelledby="experience-gallery-title">
    <h2 id="experience-gallery-title" class="section-title"><%= expText.gallery %></h2>
    <% if (expGallery.length) { %>
      <div class="featured-project-grid">
        <% expGallery.forEach(function(image) { %>
          <article class="featured-project-card">
            <img src="<%= url_for(image.src) %>" alt="<%= image.alt || expTitle + ' gallery image' %>" loading="lazy">
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <p><%= expText.noGallery %></p>
    <% } %>
  </section>

  <section class="tag-cloud" aria-labelledby="experience-links-title">
    <h2 id="experience-links-title" class="section-title"><%= expText.links %></h2>
    <div class="tag-cloud-list">
      <% if (expLinks.length) { expLinks.forEach(function(link) { %>
        <a class="tag-cloud-link" href="<%= link.url %>"><%= link.label %></a>
      <% }) } %>
      <a class="tag-cloud-link" href="<%= url_for(expBase) %>"><%= expText.back %></a>
    </div>
  </section>

  <% if (expRelated.length) { %>
    <section class="featured-projects" aria-labelledby="experience-related-title">
      <h2 id="experience-related-title" class="section-title"><%= expText.related %></h2>
      <div class="featured-project-grid">
        <% expRelated.forEach(function(item) { %>
          <a class="featured-project-card" href="<%= expUrl(item.slug) %>">
            <h3><%= item.title %></h3>
            <p><%= item.category %></p>
          </a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <nav class="post-after-actions" aria-label="<%= expText.nav %>">
    <% if (expPrev) { %><a class="os-button os-button-secondary" href="<%= expUrl(expPrev.slug) %>"><%= expText.previous %>: <%= expPrev.title %></a><% } %>
    <% if (expNext) { %><a class="os-button os-button-secondary" href="<%= expUrl(expNext.slug) %>"><%= expText.next %>: <%= expNext.title %></a><% } %>
  </nav>

  <nav class="tag-cloud-list" aria-label="<%= expText.share %>">
    <a class="tag-cloud-link" href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent(canonical) %>"><%= expText.linkedin %></a>
    <a class="tag-cloud-link" href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(canonical) %>&text=<%= encodeURIComponent(expTitle) %>"><%= expText.x %></a>
  </nav>

  <script type="application/ld+json"><%- JSON.stringify(schema) %></script>
</article>
