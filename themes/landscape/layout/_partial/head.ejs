<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<%
  const siteTitle = config.title || '';
  const metaTitle = page.title ? page.title + ' | ' + siteTitle : siteTitle;
  const rawDescription = page.description || page.excerpt || page.content || config.description || '';
  const metaDescription = (strip_html(rawDescription).replace(/\s+/g, ' ').trim() || config.description || '').slice(0, 160);
  const metaKeywords = Array.isArray(page.keywords) ? page.keywords.join(', ') : (page.keywords || config.keywords || '');
  const baseUrl = (config.url || '').replace(/\/$/, '');
  const rootPath = config.root || '/';
  const absoluteUrl = function(path) {
    if (/^https?:\/\//.test(path)) return path;
    let localPath = url_for(path).replace(/index\.html$/, '');
    if (rootPath !== '/' && localPath.indexOf(rootPath) === 0) {
      localPath = localPath.slice(rootPath.length - 1);
    }
    return baseUrl + localPath;
  };
  const canonicalUrl = page.canonical_url || absoluteUrl(page.path || '/');
  const canonicalBaseMatch = String(canonicalUrl).match(/^https?:\/\/[^/]+/);
  const canonicalBaseUrl = canonicalBaseMatch ? canonicalBaseMatch[0] : baseUrl;
  const canonicalAbsoluteUrl = function(path) {
    if (/^https?:\/\//.test(path)) return path;
    let localPath = url_for(path).replace(/index\.html$/, '');
    if (rootPath !== '/' && localPath.indexOf(rootPath) === 0) {
      localPath = localPath.slice(rootPath.length - 1);
    }
    return canonicalBaseUrl + localPath;
  };
  const shareImage = absoluteUrl(page.cover || '/images/casper-og.png');
  const shareImageAlt = page.title ? page.title + ' preview image' : siteTitle + ' preview image';
  const metaType = page.layout === 'post' ? 'article' : 'website';
  const headPath = String(page.path || '').replace(/index\.html$/, '').replace(/\/$/, '');
  const headParts = headPath.split('/').filter(Boolean);
  const headLang = headParts[0] === 'zh' ? 'zh' : (headParts[0] === 'ja' ? 'ja' : 'en');
  const ogLocales = { en: 'en_US', zh: 'zh_TW', ja: 'ja_JP' };
  const localHeadParts = headLang === 'en' ? headParts : headParts.slice(1);
  const firstHeadPart = localHeadParts[0] || '';
  const localHeadPath = localHeadParts.join('/');
  const isDatedHeadPost = /^\d{4}\/\d{2}\/\d{2}\//.test(localHeadPath);
  const headSection =
    firstHeadPart === '' ? 'home' :
    firstHeadPart === 'dashboard' ? 'dashboard' :
    firstHeadPart === 'works' ? 'projects' :
    firstHeadPart === 'archives' ? 'writing' :
    ['about', 'experience', 'projects', 'labs', 'writing', 'timeline'].includes(firstHeadPart) && localHeadParts.length === 1 ? firstHeadPart :
    null;
  const trilingualDetailPaths = [
    'experience/competitions',
    'experience/awards',
    'experience/workshops',
    'experience/speaking',
    'experience/community',
    'experience/ctf',
    'experience/projects',
    'experience/research',
    'experience/certifications',
    'projects/nihs-control-team',
    'projects/medical-cybersecurity',
    'projects/autonomous-robot',
    'labs/esp32-uart-test',
    'labs/ros2-topic-communication',
    'labs/web-security',
    'labs/medical-cybersecurity-research',
    'labs/ctf-web-practice'
  ];
  const detailHreflangPaths = trilingualDetailPaths.includes(localHeadPath) ? {
    en: '/' + localHeadPath + '/',
    zh: '/zh/' + localHeadPath + '/',
    ja: '/ja/' + localHeadPath + '/'
  } : null;
  const postHreflangPaths = isDatedHeadPost ? {
    en: '/' + localHeadPath + '/',
    zh: '/zh/' + localHeadPath + '/',
    ja: '/ja/' + localHeadPath + '/'
  } : null;
  const sectionHreflangPaths = headSection ? {
    home: { en: '/', zh: '/zh/', ja: '/ja/' },
    dashboard: { en: '/dashboard/', zh: '/zh/dashboard/', ja: '/ja/dashboard/' },
    about: { en: '/about/', zh: '/zh/about/', ja: '/ja/about/' },
    experience: { en: '/experience/', zh: '/zh/experience/', ja: '/ja/experience/' },
    projects: { en: '/projects/', zh: '/zh/projects/', ja: '/ja/projects/' },
    labs: { en: '/labs/', zh: '/zh/labs/', ja: '/ja/labs/' },
    writing: { en: '/writing/', zh: '/zh/writing/', ja: '/ja/writing/' },
    timeline: { en: '/timeline/', zh: '/zh/timeline/', ja: '/ja/timeline/' }
  }[headSection] : null;
  const hreflangPaths = detailHreflangPaths || postHreflangPaths || sectionHreflangPaths;
%>

<title><%= metaTitle %></title>
<meta name="description" content="<%= metaDescription %>">
<% if (metaKeywords) { %><meta name="keywords" content="<%= metaKeywords %>"><% } %>
<meta name="author" content="<%= config.author || '' %>">
<link rel="canonical" href="<%= canonicalUrl %>">
<% if (hreflangPaths) { %>
<link rel="alternate" hreflang="en" href="<%= canonicalAbsoluteUrl(hreflangPaths.en) %>">
<link rel="alternate" hreflang="zh-TW" href="<%= canonicalAbsoluteUrl(hreflangPaths.zh) %>">
<link rel="alternate" hreflang="ja" href="<%= canonicalAbsoluteUrl(hreflangPaths.ja) %>">
<link rel="alternate" hreflang="x-default" href="<%= canonicalAbsoluteUrl(hreflangPaths.en) %>">
<% } %>

<meta property="og:site_name" content="<%= siteTitle %>">
<meta property="og:title" content="<%= metaTitle %>">
<meta property="og:description" content="<%= metaDescription %>">
<meta property="og:type" content="<%= metaType %>">
<meta property="og:url" content="<%= canonicalUrl %>">
<meta property="og:image" content="<%= shareImage %>">
<meta property="og:image:alt" content="<%= shareImageAlt %>">
<meta property="og:locale" content="<%= ogLocales[headLang] %>">
<% if (page.date) { %>
<meta property="article:published_time" content="<%= date_xml(page.date) %>">
<% } %>
<% if (page.updated) { %>
<meta property="article:modified_time" content="<%= date_xml(page.updated) %>">
<% } %>

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= metaTitle %>">
<meta name="twitter:description" content="<%= metaDescription %>">
<meta name="twitter:image" content="<%= shareImage %>">
<meta name="twitter:image:alt" content="<%= shareImageAlt %>">

<link rel="icon" type="image/svg+xml" href="<%= url_for('/favicon.svg') %>">
<link rel="shortcut icon" href="<%= url_for('/favicon.svg') %>">
<script>
  (function() {
    try {
      document.documentElement.setAttribute('data-theme', localStorage.getItem('casper-theme') || 'light');
    } catch (error) {
      document.documentElement.setAttribute('data-theme', 'light');
    }
  })();
</script>
<link rel="stylesheet" href="<%= url_for('/css/custom.css') %>?v=20">
