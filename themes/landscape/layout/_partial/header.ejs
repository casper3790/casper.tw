<header class="site-header">
  <div class="brand-row">
    <a class="brand-avatar" href="<%= url_for('/') %>" aria-label="Home">
      <img src="<%= url_for('/images/casper.png') %>" alt="Casper avatar">
    </a>

    <div class="brand-content">
      <div class="site-kicker">
        Hi, I'm Casper.
      </div>

      <div class="site-title">
        <a href="<%= url_for('/') %>"><%= config.title %></a>
      </div>

      <div class="site-mantra">
        Learning. Building. Sharing.
      </div>

      <nav class="site-nav" aria-label="Main navigation">
        <a href="<%= url_for('/') %>">Home</a>
        <a href="<%= url_for('/works/') %>">Projects</a>
        <a href="<%= url_for('/experience/') %>">Experience</a>
        <a href="<%= url_for('/labs/') %>">Labs</a>
        <a href="<%= url_for('/archives/') %>">Writing</a>
        <a href="<%= url_for('/about/') %>">About</a>
      </nav>

      <nav class="site-nav language-switcher" aria-label="Language switcher">
        <a href="<%= url_for('/') %>" lang="en">EN</a>
        <a href="<%= url_for('/zh/about/') %>" lang="zh-Hant">中文</a>
        <a href="<%= url_for('/ja/about/') %>" lang="ja">日本語</a>
      </nav>

    </div>
  </div>
</header>
