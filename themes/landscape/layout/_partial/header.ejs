<header class="site-header">
  <%
    const normalizedPath = String(page.path || '')
      .replace(/index\.html$/, '')
      .replace(/\/$/, '');
    const pathParts = normalizedPath.split('/').filter(Boolean);
    const currentLang = pathParts[0] === 'zh' ? 'zh' : (pathParts[0] === 'ja' ? 'ja' : 'en');
    const localPathParts = currentLang === 'en' ? pathParts : pathParts.slice(1);
    const firstPathPart = localPathParts[0] || '';
    const localDetailPath = localPathParts.join('/');
    const currentSection =
      firstPathPart === '' ? 'home' :
      firstPathPart === 'dashboard' ? 'dashboard' :
      firstPathPart === 'works' ? 'projects' :
      firstPathPart === 'archives' ? 'writing' :
      ['about', 'experience', 'projects', 'labs', 'writing', 'timeline'].includes(firstPathPart) ? firstPathPart :
      'home';
    const localizedPaths = {
      en: { home: '/', dashboard: '/dashboard/', projects: '/projects/', experience: '/experience/', labs: '/labs/', writing: '/writing/', timeline: '/timeline/', about: '/about/' },
      zh: { home: '/zh/', dashboard: '/zh/dashboard/', projects: '/zh/projects/', experience: '/zh/experience/', labs: '/zh/labs/', writing: '/zh/writing/', timeline: '/zh/timeline/', about: '/zh/about/' },
      ja: { home: '/ja/', dashboard: '/ja/dashboard/', projects: '/ja/projects/', experience: '/ja/experience/', labs: '/ja/labs/', writing: '/ja/writing/', timeline: '/ja/timeline/', about: '/ja/about/' }
    };
    const trilingualDetails = [
      'experience/competitions',
      'experience/awards',
      'experience/workshops',
      'experience/speaking',
      'experience/community-teaching',
      'experience/certifications',
      'experience/leadership',
      'projects/nihs-control-team',
      'projects/medical-cybersecurity',
      'projects/autonomous-robot',
      'labs/esp32-uart-test',
      'labs/ros2-topic-communication',
      'labs/web-security',
      'labs/medical-cybersecurity-research',
      'labs/ctf-web-practice'
    ];
    const detailLangPath = function(lang, detail) {
      return lang === 'en' ? '/' + detail + '/' : '/' + lang + '/' + detail + '/';
    };
    const navPath = function(section) { return localizedPaths[currentLang][section]; };
    const langPath = function(lang) {
      if (trilingualDetails.includes(localDetailPath)) return detailLangPath(lang, localDetailPath);
      return localizedPaths[lang][currentSection];
    };
    const headerCopy = {
      en: { kicker: 'Security Lab Portfolio', mantra: 'Build · Secure · Share', home: 'Home', projects: 'Projects', experience: 'Experience', labs: 'Labs', writing: 'Writing', about: 'About', menu: 'Menu', search: 'Search' },
      zh: { kicker: 'Security Lab Portfolio', mantra: 'Build · Secure · Share', home: '首頁', projects: '專案', experience: '經歷', labs: 'Labs', writing: '文章', about: '關於', menu: '選單', search: '搜尋' },
      ja: { kicker: 'Security Lab Portfolio', mantra: 'Build · Secure · Share', home: 'ホーム', projects: 'プロジェクト', experience: '経歴', labs: 'Labs', writing: '記事', about: 'About', menu: 'メニュー', search: '検索' }
    };
    const h = headerCopy[currentLang];
    h.dashboard = h.dashboard || 'Dashboard';
  %>
  <div class="brand-row">
    <a class="brand-avatar" href="<%= url_for(navPath('home')) %>" aria-label="<%= h.home %>">
      <img src="<%= url_for('/images/casper.png') %>" alt="Casper avatar">
    </a>

    <div class="brand-content">
      <div class="site-kicker"><%= h.kicker %></div>

      <div class="site-title">
        <a href="<%= url_for(navPath('home')) %>"><span>Casper Security</span> <span>Lab OS</span></a>
      </div>

      <div class="site-mantra"><%= h.mantra %></div>

      <nav class="site-nav" aria-label="Main navigation">
        <a href="<%= url_for(navPath('dashboard')) %>"><%= h.dashboard %></a>
        <a href="<%= url_for(navPath('projects')) %>"><%= h.projects %></a>
        <a href="<%= url_for(navPath('labs')) %>"><%= h.labs %></a>
        <a href="<%= url_for(navPath('writing')) %>"><%= h.writing %></a>
        <a href="<%= url_for(navPath('experience')) %>"><%= h.experience %></a>
        <a href="<%= url_for(navPath('about')) %>"><%= h.about %></a>
      </nav>

      <div class="header-controls">
        <form class="header-search" action="<%= url_for('/search/') %>" role="search">
          <label class="sr-only" for="header-search-input"><%= h.search %></label>
          <input id="header-search-input" name="q" type="search" placeholder="<%= h.search %>" autocomplete="off">
        </form>

        <nav class="site-nav language-switcher" aria-label="Language switcher">
          <a href="<%= url_for(langPath('en')) %>" lang="en">EN</a>
          <a href="<%= url_for(langPath('zh')) %>" lang="zh-Hant">中文</a>
          <a href="<%= url_for(langPath('ja')) %>" lang="ja">日本語</a>
        </nav>

        <button class="theme-toggle-button" type="button" data-theme-toggle aria-label="Toggle color theme">Dark</button>
      </div>

      <button class="mobile-menu-button" type="button" aria-controls="mobile-nav" aria-expanded="false">
        <span class="mobile-menu-label"><%= h.menu %></span>
        <span class="mobile-menu-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>

      <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile navigation" hidden>
        <a href="<%= url_for(navPath('home')) %>"><%= h.home %></a>
        <a href="<%= url_for(navPath('dashboard')) %>"><%= h.dashboard %></a>
        <a href="<%= url_for(navPath('projects')) %>"><%= h.projects %></a>
        <a href="<%= url_for(navPath('labs')) %>"><%= h.labs %></a>
        <a href="<%= url_for(navPath('writing')) %>"><%= h.writing %></a>
        <a href="<%= url_for(navPath('experience')) %>"><%= h.experience %></a>
        <a href="<%= url_for(navPath('about')) %>"><%= h.about %></a>
        <a href="<%= url_for(langPath('en')) %>" lang="en">EN</a>
        <a href="<%= url_for(langPath('zh')) %>" lang="zh-Hant">中文</a>
        <a href="<%= url_for(langPath('ja')) %>" lang="ja">日本語</a>
        <button class="theme-toggle-button theme-toggle-button-mobile" type="button" data-theme-toggle>Dark</button>
        <a href="<%= url_for('/search/') %>"><%= h.search %></a>
      </nav>
    </div>
  </div>
</header>

<script>
  (function() {
    var storageKey = 'casper-theme';
    var root = document.documentElement;
    var buttons = Array.prototype.slice.call(document.querySelectorAll('[data-theme-toggle]'));

    function applyTheme(theme) {
      var nextTheme = theme === 'light' ? 'light' : 'dark';
      root.setAttribute('data-theme', nextTheme);
      buttons.forEach(function(button) {
        button.textContent = nextTheme === 'light' ? 'Light' : 'Dark';
        button.setAttribute('aria-pressed', String(nextTheme === 'light'));
      });
    }

    try {
      applyTheme(localStorage.getItem(storageKey) || 'dark');
    } catch (error) {
      applyTheme('dark');
    }

    buttons.forEach(function(button) {
      button.addEventListener('click', function() {
        var nextTheme = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        applyTheme(nextTheme);
        try {
          localStorage.setItem(storageKey, nextTheme);
        } catch (error) {}
      });
    });

    var menuButton = document.querySelector('.mobile-menu-button');
    var menu = document.getElementById('mobile-nav');
    var header = document.querySelector('.site-header');
    function updateHeaderState() {
      if (!header) return;
      header.classList.toggle('is-scrolled', window.scrollY > 12);
    }
    updateHeaderState();
    window.addEventListener('scroll', updateHeaderState, { passive: true });

    if (!menuButton || !menu) return;

    menuButton.addEventListener('click', function() {
      var isOpen = menuButton.getAttribute('aria-expanded') === 'true';
      menuButton.setAttribute('aria-expanded', String(!isOpen));
      menu.hidden = isOpen;
    });

    menu.addEventListener('click', function(event) {
      if (event.target && event.target.tagName === 'A') {
        menuButton.setAttribute('aria-expanded', 'false');
        menu.hidden = true;
      }
    });
  })();
</script>
