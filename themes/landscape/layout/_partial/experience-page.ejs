<%
  const expPath = String(page.path || '').replace(/index\.html$/, '').replace(/\/$/, '');
  const expParts = expPath.split('/').filter(Boolean);
  const normalizeExperienceLang = function(value) {
    const normalized = String(value || '').toLowerCase();
    if (normalized === 'zh' || normalized === 'zh-tw' || normalized === 'zh-hant') return 'zh';
    if (normalized === 'ja' || normalized === 'jp') return 'ja';
    if (normalized === 'en') return 'en';
    return '';
  };
  const expLang =
    normalizeExperienceLang(page.site_lang) ||
    (expParts[0] === 'en' ? 'en' : (expParts[0] === 'ja' ? 'ja' : (expParts[0] === 'zh' ? 'zh' : 'zh')));
  const expCopy = (site.data && site.data.experience && site.data.experience[expLang]) || site.data.experience.zh;
  const expSections = expCopy.sections || {};
  const expLabels = expCopy.labels || {};
  const expSectionOrder = ['competitions', 'camps', 'conferences', 'workshops', 'speaking', 'certifications', 'community'];

  const countSectionItems = function(section) {
    if (!section) return 0;
    if (Array.isArray(section.items)) return section.items.length;
    if (Array.isArray(section.groups)) {
      return section.groups.reduce(function(total, group) {
        return total + (Array.isArray(group.items) ? group.items.length : 0);
      }, 0);
    }
    return 0;
  };

  const renderTags = function(tags) {
    if (!Array.isArray(tags) || !tags.length) return '';
    return '<div class="experience-tags">' + tags.slice(0, 2).map(function(tag) {
      return '<span>' + tag + '</span>';
    }).join('') + '</div>';
  };

  const plainMeta = function(values) {
    return values.filter(Boolean).join(' · ');
  };

  const renderStatsSummary = function() {
    return expCopy.stats.map(function(stat) {
      return '<span><strong>' + countSectionItems(expSections[stat.key]) + '</strong> ' + stat.label + '</span>';
    }).join('<span class="experience-stat-separator" aria-hidden="true">·</span>');
  };

  const renderExperienceCard = function(item, extraClass) {
    const classes = ['experience-card'];
    if (extraClass) classes.push(extraClass);

    const result = Array.isArray(item.result) ? item.result.filter(Boolean).join(' / ') : item.result;
    const primaryMeta = plainMeta([result, item.role, item.organization]);
    const secondaryMeta = plainMeta([item.type]);
    const tagsHtml = renderTags(item.tags);

    return '<article class="' + classes.join(' ') + '">' +
      '<div class="experience-card-year">' + (item.year || '') + '</div>' +
      '<div class="experience-card-body">' +
        '<h3>' + item.name + '</h3>' +
        (primaryMeta ? '<p class="experience-card-line">' + primaryMeta + '</p>' : '') +
        (secondaryMeta ? '<p class="experience-card-subline">' + secondaryMeta + '</p>' : '') +
      '</div>' +
      (tagsHtml ? '<div class="experience-card-aside">' + tagsHtml + '</div>' : '') +
      '</article>';
  };
%>

<article class="experience-page experience-page-<%= expLang %>" lang="<%= expLang === 'zh' ? 'zh-Hant' : expLang %>">
  <section class="experience-hero" aria-labelledby="experience-page-title">
    <p class="experience-kicker"><%= expCopy.eyebrow %></p>
    <h1 id="experience-page-title"><%= expCopy.title %></h1>
    <p class="experience-subtitle"><%= expCopy.subtitle %></p>

    <div class="experience-stats-summary" aria-label="<%= expCopy.statsLabel %>">
      <%- renderStatsSummary() %>
    </div>
  </section>

  <% expSectionOrder.forEach(function(sectionKey) {
    const section = expSections[sectionKey];
    if (!section) return;
  %>
    <section class="experience-section" aria-labelledby="experience-<%= sectionKey %>-title" data-experience-section="<%= sectionKey %>">
      <div class="experience-section-header">
        <h2 id="experience-<%= sectionKey %>-title"><%= section.title %></h2>
        <p><%= countSectionItems(section) %> <%= section.title %></p>
      </div>

      <% if (sectionKey === 'speaking') { %>
        <article class="experience-card experience-muted-card">
          <h3><%= section.statusTitle %></h3>
        </article>
      <% } else if (Array.isArray(section.groups)) { %>
        <div class="experience-timeline">
          <% section.groups.forEach(function(group) { %>
            <div class="experience-year-group">
              <div class="experience-year"><%= group.year %></div>
              <div class="experience-year-items">
                <% (group.items || []).forEach(function(item) { %>
                  <%- renderExperienceCard(item, 'experience-timeline-card') %>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="experience-grid<%= (section.items || []).length === 1 ? ' experience-grid-single' : '' %>">
          <% (section.items || []).forEach(function(item) { %>
            <%- renderExperienceCard(item) %>
          <% }) %>
        </div>
      <% } %>
    </section>
  <% }) %>
</article>
