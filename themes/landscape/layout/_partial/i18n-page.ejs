  const latestLabTitle = latestLab ? latestLab[3] : 'No labs yet';
  const projectRoles = ['Full Stack Developer', 'Researcher', 'Robotics Developer'];
  const readingMinutes = function(post) {
    const raw = strip_html(post.content || post.excerpt || '').replace(/\s+/g, ' ').trim();
    const cjk = (raw.match(/[\u4e00-\u9fff\u3040-\u30ff\u3400-\u4dbf]/g) || []).length;
    const words = raw.replace(/[\u4e00-\u9fff\u3040-\u30ff\u3400-\u4dbf]/g, ' ').split(/\s+/).filter(Boolean).length;
    return Math.max(1, Math.ceil((words + cjk / 2) / 220));
  };
  const firstTag = function(post) {
    if (!post.tags || !post.tags.length) return 'Note';
    const tags = post.tags.toArray ? post.tags.toArray() : post.tags.data || [];
    return tags.length ? tags[0].name : 'Note';
  };
%>

<% function renderHomeHero() { %>
  <section id="terminal-hero" class="home-hero terminal-hero interactive-terminal-hero" aria-labelledby="<%= lang %>-home-hero-title">
    <div class="terminal-card" aria-label="Security Lab terminal">
      <div class="terminal-titlebar">
        <span class="terminal-dot terminal-dot-red"></span>
        <span class="terminal-dot terminal-dot-yellow"></span>
        <span class="terminal-dot terminal-dot-green"></span>
        <span class="terminal-title">casper@security-lab:~</span>
      </div>
      <div class="terminal-screen" data-terminal-screen>
        <div class="terminal-output" data-terminal-output>
          <div class="terminal-command-row"><span class="terminal-prompt">$</span> <button type="button" class="terminal-command" data-terminal-action="whoami">whoami</button></div>
          <div class="terminal-response">Casper<br>Hong Xin-Fu</div>
          <div class="terminal-command-row"><span class="terminal-prompt">$</span> <span class="terminal-command-label">role</span></div>
          <div class="terminal-response">Cybersecurity Student<br>Web Developer<br>Robotics Builder</div>
          <div class="terminal-command-row"><span class="terminal-prompt">$</span> <span class="terminal-command-label">currently_working_on</span></div>
          <div class="terminal-response">NIHS Control Team Platform<br><br>ROS2 Autonomous Robot<br><br>Medical Cybersecurity Research</div>
          <div class="terminal-command-row"><span class="terminal-prompt">$</span> <span class="terminal-command-label">latest_post</span></div>
          <div class="terminal-response"><%= latestPostTitle %></div>
          <div class="terminal-command-row"><span class="terminal-prompt">$</span> <span class="terminal-command-label">latest_lab</span></div>
          <div class="terminal-response"><%= latestLabTitle %></div>
          <div class="terminal-command-row"><span class="terminal-prompt">$</span> <span class="terminal-command-label">help</span></div>
          <div class="terminal-help-grid">
            <button type="button" class="terminal-command" data-terminal-action="whoami">whoami</button>
            <a class="terminal-command" href="<%= localHref('projects') %>">projects</a>
            <a class="terminal-command" href="<%= localHref('labs') %>">labs</a>
            <a class="terminal-command" href="<%= localHref('experience') %>">experience</a>
            <a class="terminal-command" href="<%= localHref('writing') %>">writing</a>
            <button type="button" class="terminal-command" data-terminal-action="clear">clear</button>
          </div>
        </div>
        <div class="terminal-command-row terminal-input-line"><span class="terminal-prompt">$</span> <span class="terminal-cursor" aria-hidden="true"></span></div>
      </div>
    </div>
    <aside class="wolf-brand-area" aria-labelledby="<%= lang %>-home-hero-title">
      <div class="wolf-mark" aria-hidden="true">
        <svg viewBox="0 0 160 160" role="img" focusable="false">
          <path d="M22 126 L42 38 L70 66 L82 22 L96 66 L124 38 L138 126 L106 142 L80 130 L54 142 Z" fill="none" stroke="currentColor" stroke-width="4" stroke-linejoin="round"/>
          <path d="M54 82 L74 92 L60 102 M106 82 L86 92 L100 102" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M70 118 L80 108 L90 118 M55 142 L80 130 L105 142" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M42 38 L54 142 M124 38 L106 142 M82 22 L80 130" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" opacity="0.48"/>
        </svg>
      </div>
      <p class="brand-eyebrow"><%= t.brand.eyebrow %></p>
      <div class="brand-roles">
        <% t.hero.home.title.forEach(function(line, index) { %>
          <strong<%- index === 0 ? ' id="' + lang + '-home-hero-title"' : '' %>><%= line %></strong>
        <% }) %>
      </div>
      <div class="brand-mission">
        <% t.brand.mission.forEach(function(line) { %><span><%= line %></span><% }) %>
      </div>
    </aside>
  </section>
  <script>
    (function() {
      var hero = document.getElementById('terminal-hero');
      if (!hero) return;
      var output = hero.querySelector('[data-terminal-output]');
      if (!output) return;
      var original = output.innerHTML;
      var restoreTimer;
      var clearedText = <%- JSON.stringify(t.terminalCleared) %>;
      hero.addEventListener('click', function(event) {
        var trigger = event.target.closest('[data-terminal-action]');
        if (!trigger) return;
        var action = trigger.getAttribute('data-terminal-action');
        if (action === 'whoami') {
          event.preventDefault();
          hero.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        if (action === 'clear') {
          event.preventDefault();
          output.innerHTML = '<div class="terminal-response terminal-cleared">' + clearedText + '</div>';
          window.clearTimeout(restoreTimer);
          restoreTimer = window.setTimeout(function() { output.innerHTML = original; }, 3000);
        }
      });
    })();
  </script>
<% } %>

