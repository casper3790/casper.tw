        </a>
      <% }) %>
    </div>
    <div class="cta-actions">
      <a class="os-button os-button-primary" href="<%= localHref('experience') %>"><%= t.nav.experience %></a>
      <a class="os-button os-button-secondary" href="<%= localHref('projects') %>"><%= t.nav.projects %></a>
      <a class="os-button os-button-secondary" href="<%= localHref('labs') %>"><%= t.nav.labs %></a>
    </div>
  </section>
<% } %>

<% function renderExperienceCards() { %>
  <section class="featured-projects" aria-labelledby="<%= lang %>-experience-cards-title">
    <h2 id="<%= lang %>-experience-cards-title" class="section-title"><%= t.hero.experience.title %></h2>
    <div class="search-box-wrap" role="search" aria-label="Filter experience">
      <input id="<%= lang %>-experience-search" class="search-input" type="search" placeholder="Search experience" autocomplete="off" data-exp-search>
      <div class="tag-cloud-list" aria-label="Experience filters">
        <select class="search-input" data-exp-filter="year" aria-label="Filter by year">
          <option value="">All years</option>
          <% Array.from(new Set(t.experienceCards.map(function(card) { return card[3]; }))).forEach(function(year) { %><option value="<%= year %>"><%= year %></option><% }) %>
        </select>
        <select class="search-input" data-exp-filter="category" aria-label="Filter by category">
          <option value="">All categories</option>
          <% Array.from(new Set(t.experienceCards.map(function(card) { return card[4]; }))).forEach(function(category) { %><option value="<%= category %>"><%= category %></option><% }) %>
        </select>
        <select class="search-input" data-exp-filter="organization" aria-label="Filter by organization">
          <option value="">All organizations</option>
          <% Array.from(new Set(t.experienceCards.map(function(card) { return card[5]; }))).forEach(function(org) { %><option value="<%= org %>"><%= org %></option><% }) %>
        </select>
        <select class="search-input" data-exp-filter="skills" aria-label="Filter by skills">
          <option value="">All skills</option>
          <% Array.from(new Set(t.experienceCards.flatMap(function(card) { return String(card[6] || '').split(','); }).map(function(skill) { return skill.trim(); }).filter(Boolean))).forEach(function(skill) { %><option value="<%= skill %>"><%= skill %></option><% }) %>
        </select>
      </div>
    </div>
    <div class="os-timeline" aria-label="Experience timeline">
      <% t.experienceCards.forEach(function(card) { %>
        <article class="timeline-card" data-exp-item data-year="<%= card[3] %>" data-category="<%= card[4] %>" data-organization="<%= card[5] %>" data-skills="<%= card[6] %>">
          <time><%= card[3] %></time>
          <div>
            <h3><a href="<%= detailHref(card[2]) %>"><%= card[0] %></a></h3>
            <p><%= card[1] %></p>
          </div>
        </article>
      <% }) %>
    </div>
    <div class="featured-project-grid">
      <% t.experienceCards.forEach(function(card) { %>
        <a class="featured-project-card" href="<%= detailHref(card[2]) %>" data-exp-item data-year="<%= card[3] %>" data-category="<%= card[4] %>" data-organization="<%= card[5] %>" data-skills="<%= card[6] %>">
          <h3><%= card[0] %></h3>
          <p><%= card[1] %></p>
          <div class="featured-project-tags" aria-label="Experience metadata">
            <span><%= card[4] %></span>
            <strong><%= card[3] %></strong>
            <strong><%= card[5] %></strong>
          </div>
          <span class="featured-project-link"><%= t.viewExperience %></span>
        </a>
      <% }) %>
    </div>
    <script>
      (function() {
        var root = document.currentScript.closest('.featured-projects');
        if (!root) return;
        var input = root.querySelector('[data-exp-search]');
        var filters = Array.prototype.slice.call(root.querySelectorAll('[data-exp-filter]'));
        var items = Array.prototype.slice.call(root.querySelectorAll('[data-exp-item]'));
        function matches(item) {
          var text = item.textContent.toLowerCase();
          var query = input ? input.value.trim().toLowerCase() : '';
          if (query && text.indexOf(query) === -1) return false;
          return filters.every(function(filter) {
            var value = filter.value;
            if (!value) return true;
            var key = filter.getAttribute('data-exp-filter');
            var data = item.getAttribute('data-' + key) || '';
            return data.indexOf(value) >= 0;
          });
        }
        function applyFilters() {
          items.forEach(function(item) {
            item.hidden = !matches(item);
          });
        }
        if (input) input.addEventListener('input', applyFilters);
        filters.forEach(function(filter) { filter.addEventListener('change', applyFilters); });
      })();
    </script>
  </section>
<% } %>

<% function renderTimeline() { %>
  <section class="os-section os-timeline-section" aria-labelledby="<%= lang %>-timeline-title">
    <div class="os-section-header">
      <p class="os-section-kicker"><%= uiCopy.timelineKicker %></p>
      <h2 id="<%= lang %>-timeline-title" class="section-title"><%= t.timeline.title %></h2>
    </div>
    <div class="os-timeline">
      <% t.timeline.items.forEach(function(item) { %>
        <article class="timeline-card"><time><%= item[0] %></time><div><h3><%= item[1] %></h3><p><%= item[2] %></p></div></article>
      <% }) %>
    </div>
  </section>
<% } %>

