<section class="home-page i18n-page i18n-page-<%= section %>" lang="<%= lang === 'zh' ? 'zh-Hant' : lang %>">
  <% if (section === 'home' || section === 'dashboard') { %>
    <% renderHomeHero(); %>
    <% renderProfilePanel(); %>
    <% renderStats(); %>
    <% renderProjects(); %>
    <% renderRecentPosts(); %>
    <% renderLabs(); %>
    <% renderTimeline(); %>
    <% renderCTA(); %>
    <% renderTagCloud(); %>
  <% } else if (section === 'about') { %>
    <% renderPageHero('about'); %>
    <% renderAbout(); %>
    <% renderGuide(); %>
  <% } else if (section === 'experience') { %>
    <% renderPageHero('experience'); %>
    <% renderExperienceCards(); %>
  <% } else if (section === 'projects') { %>
    <% renderPageHero('projects'); %>
    <% renderProjects(); %>
    <% renderLabs(); %>
  <% } else if (section === 'labs') { %>
    <% renderPageHero('labs'); %>
    <% renderLabs(); %>
    <% renderProjects(); %>
  <% } else if (section === 'writing') { %>
    <% renderPageHero('writing'); %>
    <% renderRecentPosts(); %>
    <% renderTagCloud(); %>
  <% } else if (section === 'timeline') { %>
    <% renderTimeline(); %>
    <% renderGuide(); %>
  <% } %>
</section>
