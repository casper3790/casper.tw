    <div class="tag-cloud-list">
      <a class="tag-cloud-link" href="<%= localHref('projects') %>"><%= t.nav.projects %></a>
      <a class="tag-cloud-link" href="<%= localHref('experience') %>"><%= t.nav.experience %></a>
      <a class="tag-cloud-link" href="<%= localHref('labs') %>"><%= t.nav.labs %></a>
      <a class="tag-cloud-link" href="<%= localHref('writing') %>"><%= t.nav.writing %></a>
      <a class="tag-cloud-link" href="<%= localHref('timeline') %>"><%= t.nav.timeline %></a>
      <a class="tag-cloud-link" href="<%= localHref('search') %>"><%= t.nav.search %></a>
      <a class="tag-cloud-link" href="<%= localHref('about') %>"><%= t.nav.about %></a>
    </div>
  </section>
<% } %>

<% function renderTagCloud() { %>
  <% if (tagList.length) { %>
    <section class="tag-cloud" aria-labelledby="<%= lang %>-tags-title">
      <h2 id="<%= lang %>-tags-title" class="section-title"><%= t.tags %></h2>
      <div class="tag-cloud-list">
        <% tagList.sort(function(a, b) { return String(a.name).localeCompare(String(b.name)); }).forEach(function(tag) { %>
          <a class="tag-cloud-link" href="<%= url_for(tag.path) %>" style="font-size: <%= tagSize(tag.length || 0) %>" aria-label="<%= tag.name %>, <%= tag.length %>"><%= tag.name %></a>
        <% }) %>
      </div>
    </section>
  <% } %>
<% } %>

<% function renderAbout() { %>
  <section class="featured-projects" aria-labelledby="<%= lang %>-about-content-title">
    <h2 id="<%= lang %>-about-content-title" class="section-title"><%= t.hero.about.title %></h2>
    <div class="featured-project-grid">
      <% t.aboutSections.forEach(function(item) { %>
        <a class="featured-project-card" href="<%= localHref('about') %>">
