      ['受賞歴', 'プロジェクト、Cybersecurity、ロボット、技術競技に関する受賞と評価の記録です。', 'experience/awards', '2024-2025', '受賞歴', '複数の競技', 'OSINT,Web Security,CTF,発表'],
      ['資格', 'コンピュータハードウェア、ネットワーク、安全訓練、継続的なテコンドー練習に関する資格記録です。', 'experience/certifications', '2024', '資格', '複数の認定機関', 'コンピュータハードウェア,ネットワーク,トラブルシューティング'],
      ['ワークショップ', 'Cybersecurity、クラウド、AI、オープンソース、医療デザイン、スマート製造に関する学習イベントの記録です。', 'experience/workshops', '2025', 'ワークショップ', '複数のワークショップとコミュニティイベント', 'Cybersecurity,AI,Cloud Run,オープンソース'],
      ['登壇・指導', 'CTF、Raspberry Pi、Cybersecurity 学習、ワークショップ、技術研修に関する実践的な指導支援の経験です。', 'experience/speaking', '2025', '登壇・指導', '複数の学習活動', 'CTF,Web Security,Linux,Raspberry Pi,Python'],
      ['コミュニティ', 'Cybersecurity 学習、学生間の調整、CTF 練習、Raspberry Pi 指導に関するコミュニティ活動です。', 'experience/community', '2025', 'コミュニティ', 'NIHSCEDIWHC ホワイトハットコミュニティ', 'Cybersecurity,CTF,Web Security,Linux,Raspberry Pi'],
      ['CTF 経験', 'Cybersecurity Hackathon、OSINT の評価、指導支援、Web Security 練習記録をまとめています。', 'experience/ctf', '2025-2026', 'CTF 経験', 'Cybersecurity Hackathon と学習活動', 'CTF,OSINT,Web Security,Linux'],
      ['プロジェクト', 'チーム向けプラットフォーム、Medical Cybersecurity 研究、自律ロボットに関するプロジェクト経験です。', 'experience/projects', '2025-2026', 'プロジェクト', '個人およびチームプロジェクト', 'React,FastAPI,SQLite,ROS2,Raspberry Pi'],
      ['研究', 'Medical Cybersecurity、医療ワークフロー、臨床データ検証、システムリスクに関する研究型の学習記録です。', 'experience/research', '2026', '研究', '個人研究ノート', 'Medical Cybersecurity,医療システム,リスク分析']
    ]
  }[lang];
  Object.assign(t.nav, {
    dashboard: t.nav.dashboard || 'Dashboard',
    timeline: t.nav.timeline || (lang === 'zh' ? '時間軸' : (lang === 'ja' ? 'タイムライン' : 'Timeline')),
    search: t.nav.search || 'Search'
  });
  if (!t.labsList.some(function(lab) { return lab[5] === 'labs/web-security'; })) {
    t.labsList.splice(2, 0, lang === 'zh' ? ['2026-06-16', '安全', '已完成', 'Web Security 筆記', '記錄 Web Security 基礎、request flows 與常見弱點練習。', 'labs/web-security'] : (lang === 'ja' ? ['2026-06-16', 'セキュリティ', '完了', 'Web Security メモ', 'Web Security の基礎、request flows、一般的な脆弱性練習を記録します。', 'labs/web-security'] : ['2026-06-16', 'Security', 'Completed', 'Web Security Notes', 'Recording Web Security basics, request flows, and common vulnerability practice.', 'labs/web-security']));
  }
  const href = function(targetLang, key) { return url_for(paths[targetLang || lang][key]); };
  const localHref = function(key) { return url_for(paths[lang][key]); };
  const detailHref = function(slug) { return url_for(withLang(slug)); };
  const projectHref = function(projectPath) {
    const normalizedProjectPath = String(projectPath || '').replace(/^\/+|\/+$/g, '');
    return url_for(withLang(normalizedProjectPath));
  };

  const recentPosts = [];
  const allPosts = [];
  if (site.posts && site.posts.length) {
    site.posts.toArray().sort(function(a, b) { return b.date - a.date; }).forEach(function(post, index) {
      allPosts.push(post);
      if (index < 3) recentPosts.push(post);
    });
  }
  const tagList = [];
  if (site.tags && site.tags.length) site.tags.each(function(tag) { tagList.push(tag); });
  const tagCounts = tagList.map(function(tag) { return tag.length || 0; });
  const minTagCount = tagCounts.length ? Math.min.apply(null, tagCounts) : 0;
  const maxTagCount = tagCounts.length ? Math.max.apply(null, tagCounts) : 0;
  const tagSize = function(count) {
    if (maxTagCount === minTagCount) return '1rem';
    return (0.9 + ((count - minTagCount) / (maxTagCount - minTagCount)) * 0.65).toFixed(2) + 'rem';
  };
  const awards = ['InnoServe Merit', 'OSINT Excellence', 'Creativity Award', 'Innovation Award', 'Honorable Mention'];
  const stats = [
    [String(t.projects.length).padStart(2, '0'), t.stats.projects, t.labels.currentlyBuilding, 'projects'],
    [String(site.posts && site.posts.length ? site.posts.length : 0).padStart(2, '0'), t.stats.articles, t.labels.published, 'writing'],
    [String(t.labsList.length).padStart(2, '0'), t.stats.labs, t.labels.experiments, 'labs'],
    [String(awards.length).padStart(2, '0'), t.stats.awards, t.labels.awards, 'experience/awards'],
    ['10', t.stats.workshops, t.labels.workshops, 'experience/workshops'],
    ['06', t.stats.competitions, t.labels.competitions, 'experience/competitions'],
    [String(t.projects.length + t.labsList.length).padStart(2, '0'), t.stats.repositories, t.labels.repositories, 'projects']
  ];
  const latestPost = recentPosts[0];
  const latestPostTitle = latestPost ? latestPost.title : t.noPosts;
  const latestLab = t.labsList.slice().sort(function(a, b) { return String(b[0]).localeCompare(String(a[0])); })[0];
  const latestLabTitle = latestLab ? latestLab[3] : 'No labs yet';
  const projectRoles = ['Full Stack Developer', 'Researcher', 'Robotics Developer'];
  const readingMinutes = function(post) {
    const raw = strip_html(post.content || post.excerpt || '').replace(/\s+/g, ' ').trim();
    const cjk = (raw.match(/[\u4e00-\u9fff\u3040-\u30ff\u3400-\u4dbf]/g) || []).length;
    const words = raw.replace(/[\u4e00-\u9fff\u3040-\u30ff\u3400-\u4dbf]/g, ' ').split(/\s+/).filter(Boolean).length;
    return Math.max(1, Math.ceil((words + cjk / 2) / 220));
  };
  const firstTag = function(post) {
    if (!post.tags || !post.tags.length) return 'Note';
    const tags = post.tags.toArray ? post.tags.toArray() : post.tags.data || [];
    return tags.length ? tags[0].name : 'Note';
  };
  const postTags = function(post) {
    if (!post.tags || !post.tags.length) return [];
    const tags = post.tags.toArray ? post.tags.toArray() : post.tags.data || [];
    return tags.map(function(tag) { return tag.name; }).filter(Boolean);
  };
  const postCategory = function(post) {
    if (!post.categories || !post.categories.length) return lang === 'zh' ? '筆記' : (lang === 'ja' ? 'メモ' : 'Notes');
    const categories = post.categories.toArray ? post.categories.toArray() : post.categories.data || [];
    return categories.length ? categories[0].name : (lang === 'zh' ? '筆記' : (lang === 'ja' ? 'メモ' : 'Notes'));
  };
  const postSummary = function(post) {
    const raw = post.description || post.excerpt || post.content || '';
    const text = strip_html(String(raw)).replace(/\s+/g, ' ').trim();
    return text.length > 150 ? text.slice(0, 150).replace(/\s+\S*$/, '') + '...' : text;
  };
  const writingCopy = {
    en: { all: 'All Articles', viewAll: 'View All Articles', date: 'Date', category: 'Category', tags: 'Tags', read: 'Read ->', empty: 'No articles yet.' },
    zh: { all: '全部文章', viewAll: '查看全部文章', date: '日期', category: '分類', tags: '標籤', read: '閱讀 ->', empty: '目前沒有文章。' },
    ja: { all: 'すべての記事', viewAll: 'すべての記事を見る', date: '日付', category: '分類', tags: 'タグ', read: '読む ->', empty: '記事はまだありません。' }
  }[lang];
%>

<% function renderHomeHero() { %>
