<% function renderHomeHero() { %>
  <section class="home-positioning-hero" aria-labelledby="<%= lang %>-home-hero-title">
    <div class="home-positioning-copy">
      <h1 id="<%= lang %>-home-hero-title">Casper</h1>
      <p class="home-positioning-subtitle">Find Your Polaris.</p>
      <p class="home-positioning-summary"><%= homeV1Copy.heroSummary %></p>
      <div class="cta-actions home-primary-actions">
        <a class="os-button os-button-primary" href="<%= localHref('writing') %>"><%= homeV1Copy.startReading %></a>
        <a class="os-button os-button-secondary" href="<%= localHref('writing') %>"><%= homeV1Copy.exploreNotes %></a>
      </div>
    </div>
  </section>
<% } %>

<% function renderStats() { %>
  <section class="terminal-stats-grid" aria-label="<%= uiCopy.statsLabel %>">
    <% stats.forEach(function(stat) { %>
      <a class="terminal-stat-card" href="<%= detailHref(stat[3]) %>">
        <div class="terminal-stat-number"><%= stat[0] %></div>
        <div class="terminal-stat-label"><%= stat[1] %></div>
        <div class="terminal-stat-caption"><%= stat[2] %></div>
      </a>
    <% }) %>
  </section>
<% } %>

<% function renderSpaceGuide() { %>
  <section class="site-space-guide" aria-labelledby="<%= lang %>-space-guide-title">
    <div class="site-space-guide-intro">
      <p class="site-space-guide-kicker"><%= spaceGuideCopy.kicker %></p>
      <h2 id="<%= lang %>-space-guide-title" class="section-title"><%= spaceGuideCopy.title %></h2>
      <p><%= spaceGuideCopy.body %></p>
    </div>
    <nav class="site-space-guide-list" aria-label="<%= spaceGuideCopy.kicker %>">
      <% spaceGuideCopy.items.forEach(function(item, index) { %>
        <a class="site-space-guide-row" href="<%= spaceGuideLinks[index] %>">
          <span class="site-space-guide-number"><%= String(index + 1).padStart(2, '0') %></span>
          <span class="site-space-guide-room"><%= item[0] %></span>
          <strong><%= item[1] %></strong>
          <span class="site-space-guide-desc"><%= item[2] %></span>
        </a>
      <% }) %>
    </nav>
  </section>
<% } %>

<% function renderWhyCasperExists() { %>
  <section class="why-casper-exists" aria-labelledby="<%= lang %>-why-casper-title">
    <div class="why-casper-inner">
      <header class="why-casper-header">
        <p class="why-casper-kicker"><%= uiCopy.whyKicker %></p>
        <h2 id="<%= lang %>-why-casper-title"><%= homeV1Copy.whyTitle %></h2>
      </header>
      <div class="why-casper-body">
        <% homeV1Copy.why.forEach(function(line) { %><p><%= line %></p><% }) %>
      </div>
      <a class="why-casper-link" href="<%= localHref('about') %>"><%= homeV1Copy.whyLink %></a>
    </div>
  </section>
<% } %>

<% function renderExplorationAreas() { %>
  <section class="exploration-areas" aria-labelledby="<%= lang %>-exploration-title">
    <div class="exploration-areas-inner">
      <header class="exploration-areas-header">
        <p class="exploration-areas-kicker"><%= uiCopy.areasKicker %></p>
        <h2 id="<%= lang %>-exploration-title"><%= homeV1Copy.areasTitle %></h2>
      </header>
      <div class="exploration-areas-list">
        <% homeV1Copy.areas.forEach(function(item, index) { %>
          <article class="exploration-area-item">
            <span><%= String(index + 1).padStart(2, '0') %></span>
            <h3><%= item[0] %></h3>
            <p><%= item[1] %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
<% } %>

<% function renderSelectedWorks() { %>
  <section class="selected-works" aria-labelledby="<%= lang %>-selected-works-title">
    <div class="selected-works-inner">
      <header class="selected-works-header">
        <p class="selected-works-kicker"><%= uiCopy.selectedKicker %></p>
        <h2 id="<%= lang %>-selected-works-title"><%= homeV1Copy.selectedTitle %></h2>
      </header>
      <div class="selected-works-list">
        <% const selectedLinks = [projectHref('/projects/nihs-control-team/'), projectHref('/projects/medical-cybersecurity/'), projectHref('/projects/autonomous-robot/')]; %>
        <% homeV1Copy.selected.forEach(function(item, index) { %>
          <article class="selected-work-item">
            <h3><%= item[0] %></h3>
            <p><%= item[1] %></p>
            <a href="<%= selectedLinks[index] %>"><%= homeV1Copy.selectedLink %></a>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
<% } %>

<% function renderLatestFieldNotes() { %>
  <section class="latest-field-notes" aria-labelledby="<%= lang %>-latest-notes-title">
    <div class="latest-field-notes-inner">
      <header class="latest-field-notes-header">
        <p class="latest-field-notes-kicker"><%= uiCopy.latestKicker %></p>
        <h2 id="<%= lang %>-latest-notes-title"><%= homeV1Copy.latestTitle %></h2>
      </header>
      <% if (recentPosts.length) { %>
        <div class="latest-field-notes-list">
          <% recentPosts.slice(0, 3).forEach(function(post) { %>
            <article class="latest-field-note-item">
              <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
              <h3><a href="<%= url_for(post.path) %>"><%= post.title %></a></h3>
              <% if (postSummary(post)) { %><p><%= postSummary(post) %></p><% } %>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <p class="latest-field-notes-empty"><%= t.noPosts %></p>
      <% } %>
      <a class="latest-field-notes-link" href="<%= localHref('writing') %>"><%= homeV1Copy.latestLink %></a>
    </div>
  </section>
<% } %>

<% function renderCurrentlyExploring() { %>
  <section class="currently-exploring" aria-labelledby="<%= lang %>-currently-exploring-title">
    <div class="currently-exploring-inner">
      <header class="currently-exploring-header">
        <p class="currently-exploring-kicker"><%= uiCopy.currentKicker %></p>
        <h2 id="<%= lang %>-currently-exploring-title"><%= homeV1Copy.currentTitle %></h2>
      </header>
      <div class="currently-exploring-list">
        <% homeV1Copy.current.forEach(function(item) { %>
          <article class="currently-exploring-item">
            <h3><%= item[0] %></h3>
            <p><%= item[1] %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
<% } %>

<% function renderHomeEpilogue() { %>
  <section class="home-epilogue" aria-labelledby="<%= lang %>-epilogue-title">
    <div class="home-epilogue-inner">
      <header class="home-epilogue-header">
        <p class="home-epilogue-kicker"><%= uiCopy.epilogueKicker %></p>
        <h2 id="<%= lang %>-epilogue-title"><%= homeV1Copy.epilogueTitle %></h2>
      </header>
      <div class="home-epilogue-body">
        <% homeV1Copy.epilogue.forEach(function(line) { %><p><%= line %></p><% }) %>
        <p class="home-epilogue-closing">Find Your Polaris.</p>
      </div>
    </div>
  </section>
<% } %>

<% function renderProfilePanel() { %>
  <section class="os-section os-profile-panel" aria-labelledby="<%= lang %>-profile-title">
    <div class="os-section-header">
      <p class="os-section-kicker"><%= uiCopy.profileKicker %></p>
      <h2 id="<%= lang %>-profile-title" class="section-title"><%= t.profile.title %></h2>
    </div>
    <div class="profile-panel-grid">
      <div class="profile-photo-wrap"><img class="profile-photo" src="<%= url_for('/images/casper.png') %>" alt="<%= uiCopy.imageAlt %>"></div>
      <div class="profile-panel-body">
        <p><%= t.profile.intro %></p>
        <p><%= t.profile.mission %></p>
        <blockquote class="profile-quote">"<%= t.profile.quote %>"</blockquote>
      </div>
    </div>
  </section>
<% } %>

<% function renderPageHero(key) { %>
  <section class="project-page-hero" aria-labelledby="<%= lang %>-<%= key %>-hero-title">
    <h1 id="<%= lang %>-<%= key %>-hero-title"><%= t.hero[key].title %></h1>
    <p><%= t.hero[key].body %></p>
  </section>
<% } %>

<% function renderProjects() { %>
  <section class="case-study-index" aria-labelledby="<%= lang %>-case-study-title">
    <div class="case-study-index-inner">
      <header class="case-study-index-header">
        <p><%= caseStudyCopy.kicker %></p>
        <h1 id="<%= lang %>-case-study-title"><%= caseStudyCopy.title %></h1>
        <div class="case-study-index-subtitle">
          <% caseStudyCopy.subtitle.split('\n').forEach(function(line) { %>
            <span><%= line %></span>
          <% }) %>
        </div>
      </header>
      <div class="case-study-list" aria-label="<%= caseStudyCopy.kicker %>">
        <% caseStudyCopy.items.forEach(function(project, index) { %>
          <a class="case-study-item" href="<%= caseStudyLinks[index] %>">
            <h2><%= project[0] %></h2>
            <p><%= project[1] %></p>
            <span><%= caseStudyCopy.read %></span>
          </a>
        <% }) %>
      </div>
    </div>
  </section>
<% } %>

<% function renderRecentPosts() { %>
  <section aria-labelledby="<%= lang %>-recent-posts-title">
    <h2 id="<%= lang %>-recent-posts-title" class="section-title"><%= t.recentPosts %></h2>
    <% if (recentPosts.length) { %>
      <div class="writing-list">
        <% recentPosts.forEach(function(post) { %>
          <a class="writing-item post-command-card" href="<%= url_for(post.path) %>">
            <div class="writing-date"><%= date(post.date, 'YYYY-MM-DD') %></div>
            <div class="writing-title">
              <span><%= post.title %></span>
              <div class="post-card-meta"><span><%= readingMinutes(post) %> <%= t.readTimeSuffix %></span><span><%= firstTag(post) %></span></div>
              <span class="post-read-link"><%= t.readArrow %></span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %><p><%= t.noPosts %></p><% } %>
    <p><a class="featured-project-link" href="<%= localHref('writing') %>"><%= writingCopy.viewAll %></a></p>
  </section>
<% } %>

<% function renderAllPosts() { %>
  <section class="featured-projects writing-index-section" aria-labelledby="<%= lang %>-all-posts-title">
    <h2 id="<%= lang %>-all-posts-title" class="section-title"><%= writingCopy.all %></h2>
    <% if (allPosts.length) { %>
      <div class="writing-all-list">
        <% allPosts.forEach(function(post) { const tags = postTags(post); %>
          <a class="writing-all-card" href="<%= url_for(post.path) %>">
            <div class="writing-all-date"><span><%= writingCopy.date %></span><time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY-MM-DD') %></time></div>
            <div class="writing-all-body">
              <h3><%= post.title %></h3>
              <% if (postSummary(post)) { %><p><%= postSummary(post) %></p><% } %>
              <div class="writing-all-meta">
                <span><%= writingCopy.category %>: <strong><%= postCategory(post) %></strong></span>
                <span><%= writingCopy.tags %>: <strong><%= tags.length ? tags.join(', ') : firstTag(post) %></strong></span>
              </div>
              <span class="post-read-link"><%= writingCopy.read %></span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <p><%= writingCopy.empty %></p>
    <% } %>
  </section>
<% } %>

<% function renderLabs() { %>
  <section class="lab-studio-index" aria-labelledby="<%= lang %>-lab-studio-title">
    <div class="lab-studio-index-inner">
      <header class="lab-studio-header">
        <p><%= labStudioCopy.kicker %></p>
        <h1 id="<%= lang %>-lab-studio-title"><%= labStudioCopy.title %></h1>
      </header>
      <div class="lab-experiment-list" aria-label="<%= labStudioCopy.title %>">
        <% labStudioCopy.items.forEach(function(item, index) { %>
          <article class="lab-experiment-item">
            <span class="lab-experiment-index"><%= String(index + 1).padStart(2, '0') %></span>
            <h2><%= item.title %></h2>
            <dl>
              <div>
                <dt><%= labStudioCopy.labels.what %></dt>
                <dd><%= item.what %></dd>
              </div>
              <div>
                <dt><%= labStudioCopy.labels.why %></dt>
                <dd><%= item.why %></dd>
              </div>
              <div>
                <dt><%= labStudioCopy.labels.next %></dt>
                <dd><%= item.next %></dd>
              </div>
            </dl>
            <a href="<%= labExperimentLinks[index] || localHref('labs') %>"><%= labReadCopy %></a>
          </article>
