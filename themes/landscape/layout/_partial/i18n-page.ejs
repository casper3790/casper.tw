      <h2 id="<%= lang %>-cta-title" class="section-title"><%= t.cta.title %></h2>
      <p><%= t.cta.body %></p>
    </div>
    <div class="cta-actions">
      <a class="os-button os-button-primary" href="<%= localHref('writing') %>"><%= t.cta.writing %></a>
      <a class="os-button os-button-secondary" href="<%= localHref('projects') %>"><%= t.cta.projects %></a>
      <a class="os-button os-button-secondary" href="<%= localHref('labs') %>"><%= t.cta.labs %></a>
    </div>
  </section>
<% } %>

<section class="home-page i18n-page i18n-page-<%= section %>" lang="<%= lang === 'zh' ? 'zh-Hant' : lang %>">
  <% if (section === 'home' || section === 'dashboard') { %>
    <% renderHomeHero(); %>
    <% renderSpaceGuide(); %>
    <% renderWhyCasperExists(); %>
    <% renderExplorationAreas(); %>
    <% renderSelectedWorks(); %>
    <% renderLatestFieldNotes(); %>
    <% renderCurrentlyExploring(); %>
    <% renderHomeEpilogue(); %>
  <% } else if (section === 'about') { %>
    <% renderPageHero('about'); %>
    <% renderAbout(); %>
    <% renderGuide(); %>
  <% } else if (section === 'experience') { %>
    <% renderPageHero('experience'); %>
    <% renderExperienceCards(); %>
  <% } else if (section === 'projects') { %>
    <% renderProjects(); %>
  <% } else if (section === 'labs') { %>
    <% renderLabs(); %>
  <% } else if (section === 'writing') { %>
    <% renderPageHero('writing'); %>
    <% renderAllPosts(); %>
    <% renderTagCloud(); %>
  <% } else if (section === 'timeline') { %>
    <% renderTimeline(); %>
    <% renderGuide(); %>
  <% } %>
</section>
