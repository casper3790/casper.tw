<%
  const footerPath = String(page.path || '').replace(/index\.html$/, '').replace(/\/$/, '');
  const footerParts = footerPath.split('/').filter(Boolean);
  const rawFooterText = strip_html(page.content || page.description || '').replace(/\s+/g, ' ').trim();
  const footerCjkChars = (rawFooterText.match(/[\u4e00-\u9fff\u3040-\u30ff\u3400-\u4dbf]/g) || []).length;
  const footerKanaChars = (rawFooterText.match(/[\u3040-\u30ff]/g) || []).length;
  const footerLatinChars = (rawFooterText.match(/[A-Za-z]/g) || []).length;
  const inferredFooterLang = footerKanaChars > 12 ? 'ja' : (footerCjkChars > footerLatinChars ? 'zh' : 'en');
  const isFooterPostPath = /^\d{4}\/\d{2}\/\d{2}\//.test(footerPath);
  const footerLang = footerParts[0] === 'zh' ? 'zh' : (footerParts[0] === 'ja' ? 'ja' : (isFooterPostPath ? inferredFooterLang : 'en'));
  const footerCopy = {
    en: {
      label: 'Site footer',
      title: 'Find Your Polaris.',
      note: 'Curiosity matters more than rushing to prove yourself.'
    },
    zh: {
      label: '網站頁尾',
      title: 'Find Your Polaris.',
      note: '保持好奇，比急著證明自己更重要。'
    },
    ja: {
      label: 'サイトフッター',
      title: 'Find Your Polaris.',
      note: '自分を急いで証明することより、好奇心を持ち続けることを大切にしたい。'
    }
  }[footerLang];
%>
<footer id="contact" class="site-footer polaris-footer" aria-label="<%= footerCopy.label %>">
  <p class="polaris-footer-title"><%= footerCopy.title %></p>
  <p class="polaris-footer-note"><%= footerCopy.note %></p>
  <p class="footer-copy">&copy; 2026 Casper.</p>
</footer>
